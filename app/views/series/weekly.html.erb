<div class="w-full max-w-md mx-auto flex flex-col gap-6">

  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Por semana</h1>
    <%= link_to series_path, class: "px-4 py-2 rounded-xl border-2 border-gray-200 text-sm font-semibold hover:border-gray-400 transition" do %>
      ← Volver
    <% end %>
  </div>

  <% if @weeks.empty? %>
    <p class="text-center text-gray-400 py-12">No hay series registradas aún.</p>
  <% else %>
    <% day_labels = %w[L M X J V S D] %>
    <% @weeks.each do |week| %>
      <div class="bg-white rounded-2xl shadow-lg p-5 flex flex-col gap-4">

        <div class="flex items-baseline justify-between">
          <span class="font-bold text-gray-800">
            <%= week[:start].strftime("%d %b") %> – <%= week[:end].strftime("%d %b") %>
          </span>
          <span class="text-sm text-gray-500">
            <span class="font-black text-gray-900"><%= week[:total] %></span> reps
          </span>
        </div>

        <div class="h-32">
          <canvas data-controller="line-chart"
                  data-line-chart-days-value="<%= week[:days].to_json %>"
                  data-line-chart-labels-value="<%= day_labels.to_json %>">
          </canvas>
        </div>

      </div>
    <% end %>
  <% end %>

</div>
